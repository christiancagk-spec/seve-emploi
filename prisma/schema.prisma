generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// UTILISATEURS SEVE (table séparée de la table users AGK)
// ============================================================

enum Role {
  ADMIN
  REFERENT
  LECTEUR
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  hashedPassword String
  firstName      String
  lastName       String
  role           Role      @default(REFERENT)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  companies      Company[]       @relation("CreatedByUser")
  supervisedCompanies Company[]  @relation("SupervisorUser")
  contacts       Contact[]
  reminders      Reminder[]

  @@map("seve_users")
}

// ============================================================
// SALARIÉS EN TRANSITION (table partagée avec AGK App)
// Les noms Prisma (firstName, lastName) sont mappés vers
// les colonnes françaises (prenom, nom) de la table existante.
// ============================================================

model Beneficiary {
  id                Int       @id @default(autoincrement())
  firstName         String    @map("prenom")
  lastName          String    @map("nom")
  email             String?   @default("")
  phone             String?   @default("") @map("telephone")
  notes             String?   @default("")
  targetJob         String?   @default("") @map("target_job")

  // Champs AGK existants
  dateNaissance     DateTime? @map("date_naissance") @db.Date
  adresse           String?   @default("")
  situation         String?   @default("")
  cipId             Int?      @map("cip_id")
  dateEntreeAci     DateTime? @map("date_entree_aci") @db.Date
  dateSortieAci     DateTime? @map("date_sortie_aci") @db.Date
  typeContrat       String?   @default("CDDI") @map("type_contrat")
  motifSortie       String?   @map("motif_sortie")
  heuresTravaillees Decimal?  @default(0) @map("heures_travaillees") @db.Decimal(8, 2)
  numeroAsp         String?   @map("numero_asp")
  encadrantReferent String?   @map("encadrant_referent")
  statutParcours    String?   @default("actif") @map("statut_parcours")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @map("updated_at")

  // Relations SEVE
  prospections      Prospection[]
  contacts          Contact[]
  reminders         Reminder[]

  @@map("beneficiaires")
}

// ============================================================
// ENTREPRISES (PROSPECTION)
// ============================================================

enum ContactStatus {
  EN_ATTENTE
  PMSMP
  CONTRAT
  REFUS
}

model Company {
  id             String        @id @default(cuid())
  companyName    String
  address        String        @default("")
  city           String        @default("")
  phone          String        @default("")
  email          String        @default("")
  sector         String        @default("")
  contactStatus  ContactStatus @default(EN_ATTENTE)
  notes          String        @default("")
  deleted        Boolean       @default(false)
  deletedAt      DateTime?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  createdBy      User          @relation("CreatedByUser", fields: [createdById], references: [id])
  createdById    String
  supervisor     User          @relation("SupervisorUser", fields: [supervisorId], references: [id])
  supervisorId   String

  contacts       Contact[]
  reminders      Reminder[]
  prospections   Prospection[]
  companyContacts CompanyContact[]

  @@index([supervisorId])
  @@index([contactStatus])
  @@index([sector])
  @@index([deleted])
  @@map("companies")
}

// ============================================================
// CONTACTS D'ENTREPRISE (personnes physiques)
// ============================================================

model CompanyContact {
  id        String   @id @default(cuid())
  name      String
  position  String   @default("")
  phone     String   @default("")
  email     String   @default("")

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_contacts")
}

// ============================================================
// HISTORIQUE DES INTERACTIONS
// ============================================================

enum ContactType {
  APPEL
  EMAIL
  VISITE
  AUTRE
}

enum ContactOutcome {
  POSITIF
  NEGATIF
  EN_ATTENTE
}

model Contact {
  id            String         @id @default(cuid())
  date          DateTime       @default(now())
  type          ContactType
  outcome       ContactOutcome @default(EN_ATTENTE)
  comment       String         @default("")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId     String

  beneficiary   Beneficiary?   @relation(fields: [beneficiaryId], references: [id])
  beneficiaryId Int?

  createdBy     User           @relation(fields: [createdById], references: [id])
  createdById   String

  createdAt     DateTime       @default(now())

  @@index([companyId])
  @@index([beneficiaryId])
  @@index([date])
  @@map("contacts")
}

// ============================================================
// PROSPECTIONS (liaison salarié en transition/entreprise)
// ============================================================

enum ProspectionStatus {
  EN_COURS
  PMSMP
  CONTRAT
  REFUS
  TERMINE
}

model Prospection {
  id            String            @id @default(cuid())
  status        ProspectionStatus @default(EN_COURS)
  startDate     DateTime          @default(now())
  endDate       DateTime?
  notes         String            @default("")
  outcome       String            @default("")

  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId     String

  beneficiary   Beneficiary       @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  beneficiaryId Int

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([companyId])
  @@index([beneficiaryId])
  @@index([status])
  @@map("prospections")
}

// ============================================================
// RAPPELS & ÉCHÉANCES
// ============================================================

enum ReminderType {
  SUIVI
  ECHEANCE
  OPPORTUNITE
}

enum ReminderStatus {
  EN_ATTENTE
  COMPLETE
  ANNULE
}

model Reminder {
  id            String         @id @default(cuid())
  date          DateTime
  type          ReminderType   @default(SUIVI)
  status        ReminderStatus @default(EN_ATTENTE)
  comment       String         @default("")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId     String

  beneficiary   Beneficiary?   @relation(fields: [beneficiaryId], references: [id])
  beneficiaryId Int?

  createdBy     User           @relation(fields: [createdById], references: [id])
  createdById   String

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId])
  @@index([date])
  @@map("reminders")
}